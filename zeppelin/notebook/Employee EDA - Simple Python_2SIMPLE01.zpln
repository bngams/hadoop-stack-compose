    {
      "title": "Step 1: Install Required Libraries",
      "text": "%python\n\nimport subprocess\nimport sys\n\n# Install required packages\nprint(\"📦 Installing pandas, matplotlib, seaborn...\")\nsubprocess.check_call([sys.executable, \"-m\", \"pip\", \"install\", \"-q\", \"pandas\", \"matplotlib\", \"seaborn\"])\nprint(\"✅ Packages installed successfully!\")",
      "user": "anonymous",
      "dateUpdated": "2026-03-19T00:00:00+0000",
