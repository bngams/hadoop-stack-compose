    {
      "title": "Step 2: Load Data",
      "text": "%python\n\nimport pandas as pd\nimport matplotlib.pyplot as plt\nimport seaborn as sns\n\n# Set plotting style\nsns.set_theme(style=\"whitegrid\")\n\nprint(\"📂 Loading employee data...\")\n\n# Try to load from mounted data directory\ntry:\n    df = pd.read_csv(\"/zeppelin/data/output/integrated_employees.csv\")\n    print(f\"✅ Data loaded: {len(df)} records\")\n    print(f\"Columns: {list(df.columns)}\")\n    print(\"\\nFirst 5 rows:\")\n    print(df.head())\nexcept FileNotFoundError:\n    print(\"❌ File not found!\")\n    print(\"\\nPlease run these commands first:\")\n    print(\"docker exec namenode hdfs dfs -get /user/python-etl/employees/integrated_employees.csv /tmp/\")\n    print(\"docker cp namenode:/tmp/integrated_employees.csv ./data/output/\")",
