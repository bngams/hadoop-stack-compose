        "forms": {}
      },
      "apps": [],
      "runtimeInfos": {},
      "progressUpdateIntervalMs": 500,
      "jobName": "paragraph_3",
      "id": "paragraph_3",
      "dateCreated": "2026-03-19T00:00:00+0000",
      "status": "READY"
    },
    {
      "title": "Step 3: Data Schema & Quality Check",
      "text": "%pyspark\n\nprint(\"=\" * 60)\nprint(\"DATA SCHEMA\")\nprint(\"=\" * 60)\ndf.printSchema()\n\nprint(\"\\n\" + \"=\" * 60)\nprint(\"DATA SUMMARY\")\nprint(\"=\" * 60)\nprint(f\"Total records: {df.count()}\")\nprint(f\"Total columns: {len(df.columns)}\")\n\n# Check for null values\nprint(\"\\n\" + \"=\" * 60)\nprint(\"MISSING VALUES\")\nprint(\"=\" * 60)\n\nnull_counts = df.select([\n    spark_sum(col(c).isNull().cast(\"int\")).alias(c)\n    for c in df.columns\n])\n\nnull_counts.show()",
      "user": "anonymous",
      "dateUpdated": "2026-03-19T00:00:00+0000",
      "progress": 0,
      "config": {
        "colWidth": 12,
        "enabled": true,
        "results": {},
        "editorSetting": {
          "language": "python",
          "editOnDblClick": false
        },
        "editorMode": "ace/mode/python",
        "title": true
      },
      "settings": {
        "params": {},
        "forms": {}
      },
      "apps": [],
      "runtimeInfos": {},
      "progressUpdateIntervalMs": 500,
      "jobName": "paragraph_4",
      "id": "paragraph_4",
      "dateCreated": "2026-03-19T00:00:00+0000",
      "status": "READY"
    },
    {
      "title": "Step 4: Clean Salary Column",
      "text": "%pyspark\n\n# Clean salary column - extract numeric value from \"20000euro/an\"\ndf_cleaned = df.withColumn(\n    \"Salaire_numeric\",\n    regexp_extract(col(\"Salaire\"), r'(\\\\d+)', 1).cast(\"int\")\n)\n\nprint(\"✅ Salary column cleaned\")\nprint(\"\\nBefore and After:\")\ndf_cleaned.select(\"nom\", \"Salaire\", \"Salaire_numeric\").show(5)",
      "user": "anonymous",
      "dateUpdated": "2026-03-19T00:00:00+0000",
      "progress": 0,
      "config": {
        "colWidth": 12,
        "enabled": true,
        "results": {},
        "editorSetting": {
          "language": "python",
          "editOnDblClick": false
        },
        "editorMode": "ace/mode/python",
        "title": true
      },
      "settings": {
        "params": {},
        "forms": {}
      },
      "apps": [],
      "runtimeInfos": {},
      "progressUpdateIntervalMs": 500,
      "jobName": "paragraph_5",
      "id": "paragraph_5",
      "dateCreated": "2026-03-19T00:00:00+0000",
      "status": "READY"
    },
    {
      "title": "Step 5: Salary Statistics",
      "text": "%pyspark\n\nprint(\"=\" * 60)\nprint(\"💰 SALARY STATISTICS\")\nprint(\"=\" * 60)\n\nsalary_stats = df_cleaned.select(\n    avg(\"Salaire_numeric\").alias(\"avg_salary\"),\n    min(\"Salaire_numeric\").alias(\"min_salary\"),\n    max(\"Salaire_numeric\").alias(\"max_salary\")\n).collect()[0]\n\nprint(f\"Average salary: {salary_stats.avg_salary:,.0f} €\")\nprint(f\"Min salary: {salary_stats.min_salary:,.0f} €\")\nprint(f\"Max salary: {salary_stats.max_salary:,.0f} €\")\n\nprint(\"\\nDetailed Statistics:\")\ndf_cleaned.select(\"Salaire_numeric\").summary().show()",
      "user": "anonymous",
      "dateUpdated": "2026-03-19T00:00:00+0000",
      "progress": 0,
      "config": {
        "colWidth": 12,
        "enabled": true,
        "results": {},
        "editorSetting": {
          "language": "python",
          "editOnDblClick": false
        },
        "editorMode": "ace/mode/python",
        "title": true
      },
      "settings": {
