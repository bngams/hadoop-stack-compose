      "status": "READY"
    },
    {
      "title": "Step 8: SQL Query with Visualization",
      "text": "%sql\n\n-- Average salary by sector (for sectors with 2+ employees)\n-- Click the chart icon above to visualize!\n\nSELECT \n    Secteur,\n    ROUND(AVG(Salaire_numeric), 0) as avg_salary,\n    COUNT(*) as employee_count\nFROM employee_data\nGROUP BY Secteur\nHAVING COUNT(*) >= 2\nORDER BY avg_salary DESC",
      "user": "anonymous",
      "dateUpdated": "2026-03-19T00:00:00+0000",
      "progress": 0,
