        "forms": {}
      },
      "apps": [],
      "runtimeInfos": {},
      "progressUpdateIntervalMs": 500,
      "jobName": "paragraph_6",
      "id": "paragraph_6",
      "dateCreated": "2026-03-19T00:00:00+0000",
      "status": "READY"
    },
    {
      "title": "Step 6: Distribution Analysis",
      "text": "%pyspark\n\nprint(\"=\" * 60)\nprint(\"DISTRIBUTION ANALYSIS\")\nprint(\"=\" * 60)\n\nprint(\"\\n👥 GENDER DISTRIBUTION:\")\ndf_cleaned.groupBy(\"Sexe\").count().orderBy(desc(\"count\")).show()\n\nprint(\"\\n🏢 TOP 5 SECTORS:\")\ndf_cleaned.groupBy(\"Secteur\").count().orderBy(desc(\"count\")).limit(5).show(truncate=False)\n\nprint(\"\\n💼 TOP 5 JOB FUNCTIONS:\")\ndf_cleaned.groupBy(\"Fonction\").count().orderBy(desc(\"count\")).limit(5).show(truncate=False)",
      "user": "anonymous",
      "dateUpdated": "2026-03-19T00:00:00+0000",
      "progress": 0,
      "config": {
