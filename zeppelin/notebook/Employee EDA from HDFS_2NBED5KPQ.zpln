    },
    {
      "title": "Step 7: Register SQL Table",
      "text": "%pyspark\n\n# Register DataFrame as SQL table for querying\ndf_cleaned.createOrReplaceTempView(\"employee_data\")\n\nprint(\"✅ DataFrame registered as SQL table 'employee_data'\")\nprint(\"\\nYou can now use %sql to query this data!\")",
      "user": "anonymous",
      "dateUpdated": "2026-03-19T00:00:00+0000",
      "progress": 0,
      "config": {
        "colWidth": 12,
        "enabled": true,
        "results": {},
