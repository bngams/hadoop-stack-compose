      "status": "READY",
      "focus": true,
      "$$hashKey": "object:1"
    },
    {
      "title": "Step 1: Initialize Spark",
      "text": "%pyspark\n\n# Import libraries\nfrom pyspark.sql import SparkSession\nfrom pyspark.sql.functions import col, count, avg, min, max, desc, regexp_extract, sum as spark_sum\nimport matplotlib.pyplot as plt\nimport seaborn as sns\n\n# Initialize Spark session\nspark = SparkSession.builder \\\n    .appName(\"Employee EDA\") \\\n    .getOrCreate()\n\nspark.sparkContext.setLogLevel(\"WARN\")\n\nprint(\"✅ Spark session initialized\")\nprint(f\"Spark version: {spark.version}\")",
      "user": "anonymous",
      "dateUpdated": "2026-03-19T00:00:00+0000",
      "progress": 0,
      "config": {
        "colWidth": 12,
        "enabled": true,
        "results": {},
        "editorSetting": {
          "language": "python",
          "editOnDblClick": false
        },
        "editorMode": "ace/mode/python",
        "title": true
      },
      "settings": {
        "params": {},
        "forms": {}
      },
      "apps": [],
      "runtimeInfos": {},
      "progressUpdateIntervalMs": 500,
      "jobName": "paragraph_2",
      "id": "paragraph_2",
      "dateCreated": "2026-03-19T00:00:00+0000",
      "status": "READY"
    },
    {
      "title": "Step 2: Load Data from HDFS",
      "text": "%pyspark\n\n# Load data from HDFS\nhdfs_path = \"hdfs://namenode:8020/user/python-etl/employees/integrated_employees.csv\"\n\nprint(f\"📂 Loading data from: {hdfs_path}\")\n\ndf = spark.read.csv(\n    hdfs_path,\n    header=True,\n    inferSchema=True,\n    sep=','\n)\n\nprint(f\"✅ Data loaded: {df.count()} records\")\nprint(f\"Columns: {df.columns}\\n\")\n\n# Show first few rows\ndf.show(5, truncate=False)",
      "user": "anonymous",
      "dateUpdated": "2026-03-19T00:00:00+0000",
      "progress": 0,
      "config": {
        "colWidth": 12,
        "enabled": true,
        "results": {},
        "editorSetting": {
          "language": "python",
          "editOnDblClick": false
        },
        "editorMode": "ace/mode/python",
        "title": true
