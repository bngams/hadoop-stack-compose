    },
    {
      "title": "Step 11: Export Results to HDFS",
      "text": "%pyspark\n\n# Save analysis results back to HDFS\noutput_path = \"hdfs://namenode:8020/user/python-etl/analysis_results/salary_by_sector\"\n\nprint(f\"💾 Saving analysis results to HDFS...\")\nprint(f\"Path: {output_path}\")\n\nsalary_analysis.write \\\n    .mode(\"overwrite\") \\\n    .option(\"header\", \"true\") \\\n    .csv(output_path)\n\nprint(f\"\\n✅ Analysis results saved successfully!\")\nprint(f\"\\nTo view the results, run:\")\nprint(f\"docker exec -it namenode hdfs dfs -ls {output_path.replace('hdfs://namenode:8020', '')}\")",
      "user": "anonymous",
      "dateUpdated": "2026-03-19T00:00:00+0000",
      "progress": 0,
      "config": {
        "colWidth": 12,
